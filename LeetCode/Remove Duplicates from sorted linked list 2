class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) 
    {
        ListNode* dummy = new ListNode(0 , head);
        dummy->next = head;
        ListNode* temp = head;
        ListNode* prev = dummy;
        while(temp->next != NULL)
        {
            if(temp!= NULL && temp->val == temp->next->val)
            {
                while(temp->next != NULL && temp->val == temp->next->val)
                {
                    temp = temp->next;
                }
                prev->next = temp->next;
            }
            else
            {
                prev = prev->next;
            }
            temp = temp->next;
        }
        return dummy->next;
    }
};
